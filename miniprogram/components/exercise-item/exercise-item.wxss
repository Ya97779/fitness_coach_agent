.ex-card {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.ex-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: var(--text-secondary);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.ex-info {
  flex: 1;
}

.ex-name {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
}

.ex-meta {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
  display: block;
}

.ex-cal {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
