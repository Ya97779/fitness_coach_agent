.food-card {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}

.food-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: #a8b5a0;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 28rpx;
  color: #f0ece4;
  display: block;
}

.food-meta {
  font-size: 20rpx;
  color: rgba(255,255,255,0.25);
  margin-top: 2rpx;
  display: block;
}

.food-cal {
  font-size: 28rpx;
  font-weight: 600;
  color: #f0ece4;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
