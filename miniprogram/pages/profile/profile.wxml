<view class="page">
  <!-- 用户头部 -->
  <view class="profile-header">
    <image class="avatar" src="{{userInfo.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="user-name">{{userInfo.nickname || '未设置昵称'}}</text>
    </view>
  </view>

  <!-- 身体数据 -->
  <view class="card">
    <text class="card-label">身体数据</text>
    <view class="data-grid">
      <view class="data-item">
        <text class="data-val">{{userInfo.height || '--'}}</text>
        <text class="data-unit">cm</text>
      </view>
      <view class="data-item">
        <text class="data-val">{{userInfo.weight || '--'}}</text>
        <text class="data-unit">kg</text>
      </view>
      <view class="data-item">
        <text class="data-val">{{userInfo.age || '--'}}</text>
        <text class="data-unit">岁</text>
      </view>
      <view class="data-item">
        <text class="data-val">{{userInfo.gender || '--'}}</text>
        <text class="data-unit"></text>
      </view>
    </view>
  </view>

  <!-- 代谢数据 -->
  <view class="card">
    <text class="card-label">代谢指标</text>
    <view class="data-grid">
      <view class="data-item">
        <text class="data-val">{{userInfo.bmr ? Math.round(userInfo.bmr) : '--'}}</text>
        <text class="data-unit">kcal · BMR</text>
      </view>
      <view class="data-item">
        <text class="data-val">{{userInfo.tdee ? Math.round(userInfo.tdee) : '--'}}</text>
        <text class="data-unit">kcal · TDEE</text>
      </view>
    </view>
  </view>

  <!-- 目标信息 -->
  <view class="card" wx:if="{{userInfo.target_weight || userInfo.allergies}}">
    <text class="card-label">目标信息</text>
    <view class="info-row" wx:if="{{userInfo.target_weight}}">
      <text class="info-key">目标体重</text>
      <text class="info-val">{{userInfo.target_weight}} kg</text>
    </view>
    <view class="info-row" wx:if="{{userInfo.allergies}}">
      <text class="info-key">过敏源</text>
      <text class="info-val">{{userInfo.allergies}}</text>
    </view>
  </view>

  <!-- 编辑 -->
  <view class="edit-row" bindtap="showEdit">
    <text class="edit-text">编辑个人资料</text>
    <text class="edit-arrow">></text>
  </view>

  <!-- 编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="hideEdit">
    <view class="modal-content" catchtap="">
      <text class="modal-title">编辑资料</text>
      <view class="form-group">
        <text class="form-label">身高 (cm)</text>
        <input class="form-input" type="digit" value="{{editForm.height}}" bindinput="onEditInput" data-field="height" />
      </view>
      <view class="form-group">
        <text class="form-label">体重 (kg)</text>
        <input class="form-input" type="digit" value="{{editForm.weight}}" bindinput="onEditInput" data-field="weight" />
      </view>
      <view class="form-group">
        <text class="form-label">年龄</text>
        <input class="form-input" type="number" value="{{editForm.age}}" bindinput="onEditInput" data-field="age" />
      </view>
      <view class="form-group">
        <text class="form-label">性别</text>
        <view class="gender-btns">
          <view class="gender-btn {{editForm.gender === '男' ? 'gender-active' : ''}}" bindtap="selectGender" data-gender="男">男</view>
          <view class="gender-btn {{editForm.gender === '女' ? 'gender-active' : ''}}" bindtap="selectGender" data-gender="女">女</view>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">目标体重 (kg)</text>
        <input class="form-input" type="digit" value="{{editForm.target_weight}}" bindinput="onEditInput" data-field="target_weight" />
      </view>
      <view class="form-group">
        <text class="form-label">过敏源</text>
        <input class="form-input" value="{{editForm.allergies}}" bindinput="onEditInput" data-field="allergies" />
      </view>
      <view class="modal-btns">
        <view class="btn-secondary" bindtap="hideEdit">取消</view>
        <view class="btn-primary" bindtap="saveProfile">保存</view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="logout">退出登录</view>
</view>
