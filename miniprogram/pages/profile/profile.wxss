.page {
  padding: 0 32rpx 40rpx;
}

/* 头部 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #E8F5E9;
  margin-right: 28rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 数据网格 */
.card-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.data-grid {
  display: flex;
  flex-wrap: wrap;
}

.data-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.data-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
}

.data-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.data-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 编辑卡片 */
.edit-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.edit-text {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
}

.edit-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #fff;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  background: #F8F9FA;
  border: 2rpx solid #F0F0F0;
  border-radius: 10rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
}

.gender-btns {
  display: flex;
  gap: 20rpx;
}

.gender-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #F8F9FA;
  border-radius: 10rpx;
  border: 2rpx solid transparent;
}

.gender-active {
  color: #4CAF50;
  border-color: #4CAF50;
  background: rgba(76, 175, 80, 0.06);
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-btns .btn-secondary,
.modal-btns .btn-primary {
  flex: 1;
}

/* 退出登录 */
.logout-btn {
  text-align: center;
  color: #F44336;
  font-size: 28rpx;
  padding: 32rpx;
  margin-top: 16rpx;
}
