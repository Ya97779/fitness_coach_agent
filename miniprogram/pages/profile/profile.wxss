.page {
  padding: 0 28rpx 40rpx;
}

/* 头部 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--bg-card);
  margin-right: 24rpx;
  border: 1rpx solid var(--border);
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* 数据网格 */
.card-label {
  font-size: 20rpx;
  color: var(--text-hint);
  letter-spacing: 3rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
}

.data-grid {
  display: flex;
  flex-wrap: wrap;
}

.data-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.data-val {
  font-size: 44rpx;
  font-weight: 200;
  color: var(--text-primary);
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.data-unit {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.info-row:last-child {
  border-bottom: none;
}

.info-key {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-val {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 编辑行 */
.edit-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  margin-top: 8rpx;
}

.edit-text {
  font-size: 28rpx;
  color: var(--accent);
  font-weight: 500;
}

.edit-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: var(--bg-base);
  width: 100%;
  border-radius: var(--radius-md) var(--radius-md) 0 0;
  padding: 36rpx 28rpx;
  max-height: 80vh;
  overflow-y: auto;
  border-top: 1rpx solid var(--border);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 10rpx;
  display: block;
  letter-spacing: 1rpx;
}

.form-input {
  background: var(--bg-input);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.gender-btns {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: var(--text-hint);
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.gender-active {
  color: var(--accent);
  border-color: var(--accent);
  background: var(--accent-dim);
}

.modal-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.modal-btns .btn-secondary,
.modal-btns .btn-primary {
  flex: 1;
}

/* 退出登录 */
.logout-btn {
  text-align: center;
  color: var(--danger);
  font-size: 26rpx;
  padding: 32rpx;
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}
