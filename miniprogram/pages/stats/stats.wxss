.page {
  padding: 0 32rpx 40rpx;
}

/* 日期范围 */
.range-tabs {
  display: flex;
  background: #F0F0F0;
  border-radius: 12rpx;
  padding: 6rpx;
  margin: 24rpx 0;
}

.range-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.range-active {
  background: #fff;
  color: #4CAF50;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 图表 */
.chart-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.chart-canvas {
  width: 100%;
  height: 360rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
