.page {
  padding: 20rpx 28rpx;
}

/* 搜索框 */
.search-bar {
  margin-bottom: 24rpx;
}

.search-input {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 搜索结果 */
.search-results {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.search-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.search-item:last-child {
  border-bottom: none;
}

.search-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.search-group-tag {
  font-size: 20rpx;
  color: var(--text-hint);
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

/* 肌群卡片 */
.group-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.group-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 24rpx;
}

.group-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  background: rgba(255,255,255,0.03);
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.group-emoji {
  font-size: 36rpx;
}

.group-info {
  flex: 1;
  min-width: 0;
}

.group-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.group-func {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 12rpx;
}

.group-count {
  font-size: 28rpx;
  font-weight: 200;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}

.group-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
}
