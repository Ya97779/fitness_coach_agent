.page {
  padding-bottom: 140rpx;
}

/* 媒体 */
.media-wrap {
  width: 100%;
  background: #000;
}

.video-player {
  width: 100%;
  height: 400rpx;
}

.gif-image {
  width: 100%;
  height: 400rpx;
}

.media-empty {
  width: 100%;
  height: 300rpx;
  background: rgba(255,255,255,0.03);
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-empty-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 信息区 */
.info-section {
  padding: 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.ex-name {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-sm);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.equip-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.equip-key {
  font-size: 22rpx;
  color: var(--text-hint);
}

.equip-val {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* Tab 切换 */
.detail-tabs {
  display: flex;
  border-bottom: 1rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
  background: var(--bg-base);
}

.detail-tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 24rpx;
  color: var(--text-hint);
  position: relative;
  transition: all 0.15s;
  letter-spacing: 1rpx;
}

.tab-on {
  color: var(--text-primary);
  font-weight: 600;
}

.tab-on::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: var(--accent);
}

/* 内容区 */
.tab-body {
  padding: 24rpx 28rpx;
}

/* 步骤 */
.step-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.step-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
}

/* 细节 */
.tip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.tip-icon {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 700;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
}

/* 错误 */
.mistake-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mistake-item {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 20rpx;
}

.mistake-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.mistake-row:last-child {
  margin-bottom: 0;
}

.mistake-icon {
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.mistake-icon.bad {
  color: var(--danger);
}

.mistake-icon.good {
  color: var(--accent);
}

.mistake-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 变体 */
.var-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.var-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 20rpx;
}

.var-info {
  flex: 1;
}

.var-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.var-desc {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
  display: block;
}

.var-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 空数据 */
.no-data {
  text-align: center;
  padding: 60rpx 0;
}

.no-data-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent 0%, var(--bg-base) 30%);
  z-index: 20;
}

.bottom-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.bottom-btn.primary {
  background: var(--text-primary);
  color: var(--bg-base);
}

.bottom-btn.secondary {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  color: var(--text-secondary);
}

.bottom-btn-text {
  font-size: 28rpx;
}
