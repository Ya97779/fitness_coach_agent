.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-base);
}

/* 肌群头部 */
.group-header {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}

.header-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.header-func {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
  display: block;
}

/* 分栏布局 */
.split-layout {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧导航 */
.sidebar {
  width: 180rpx;
  background: rgba(255,255,255,0.02);
  flex-shrink: 0;
  border-right: 1rpx solid var(--border);
}

.sidebar-item {
  position: relative;
  padding: 28rpx 20rpx;
  text-align: center;
  transition: all 0.15s;
}

.sidebar-text {
  font-size: 24rpx;
  color: var(--text-hint);
  transition: all 0.15s;
  letter-spacing: 1rpx;
}

.sidebar-on .sidebar-text {
  color: var(--text-primary);
  font-weight: 600;
}

.sidebar-bar {
  position: absolute;
  right: 0;
  top: 20%;
  bottom: 20%;
  width: 4rpx;
  background: var(--accent);
}

/* 右侧内容 */
.content {
  flex: 1;
  padding: 12rpx 16rpx;
}

/* 动作卡片 */
.ex-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 16rpx;
  margin-bottom: 12rpx;
  position: relative;
}

.ex-gif {
  width: 100%;
  height: 260rpx;
  border-radius: var(--radius-sm);
  background: rgba(255,255,255,0.03);
}

.ex-gif-empty {
  width: 100%;
  height: 260rpx;
  border-radius: var(--radius-sm);
  background: rgba(255,255,255,0.03);
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ex-gif-char {
  font-size: 56rpx;
  font-weight: 200;
  color: var(--text-muted);
}

.ex-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-top: 12rpx;
  text-align: center;
}

/* 难度指示点 */
.diff-dot {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 2rpx;
}

/* 空状态 */
.empty-sub {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 24rpx;
  color: var(--text-hint);
}
