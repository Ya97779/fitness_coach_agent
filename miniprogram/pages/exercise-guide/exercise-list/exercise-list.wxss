.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F7FA;
}

/* 肌群头部 */
.group-header {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  padding: 24rpx 32rpx;
  flex-shrink: 0;
}

.group-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2E7D32;
  display: block;
}

.group-functions {
  font-size: 22rpx;
  color: #558B2F;
  margin-top: 4rpx;
  display: block;
}

/* 分栏布局 */
.split-layout {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧导航 */
.sidebar {
  width: 180rpx;
  background: #fff;
  flex-shrink: 0;
  border-right: 1rpx solid #F0F0F0;
}

.sidebar-item {
  position: relative;
  padding: 28rpx 20rpx;
  text-align: center;
  transition: all 0.2s;
}

.sidebar-text {
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.sidebar-active .sidebar-text {
  color: #4CAF50;
  font-weight: 600;
}

.sidebar-indicator {
  position: absolute;
  right: 0;
  top: 20%;
  bottom: 20%;
  width: 6rpx;
  background: #4CAF50;
  border-radius: 3rpx;
}

/* 右侧内容 */
.content {
  flex: 1;
  padding: 16rpx 20rpx;
}

/* 动作卡片 */
.ex-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.ex-gif {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
  background: #F0F0F0;
}

.ex-gif-placeholder {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-char {
  font-size: 64rpx;
  font-weight: 700;
  color: #4CAF50;
  opacity: 0.5;
}

.ex-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-top: 16rpx;
  text-align: center;
}

/* 难度指示点 */
.diff-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 空状态 */
.empty-sub {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #ccc;
}
