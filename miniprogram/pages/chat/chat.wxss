.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-base);
}

/* 快捷入口 */
.shortcuts-bar {
  white-space: nowrap;
  padding: 16rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 22rpx;
  margin-right: 12rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.chip-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 24rpx 28rpx;
}

.msg-item {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.msg-item.user {
  flex-direction: row-reverse;
}

/* AI 头像 */
.msg-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 14rpx;
  background: var(--accent-dim);
  color: var(--accent);
  letter-spacing: 1rpx;
}

.msg-item.user .msg-avatar {
  margin-right: 0;
  margin-left: 14rpx;
}

/* 气泡 */
.msg-bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  word-break: break-all;
}

.bubble-user {
  background: var(--accent-dim);
  color: var(--text-primary);
}

.bubble-ai {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  color: var(--text-primary);
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
}

/* 加载动画 */
.msg-loading {
  display: flex;
  gap: 8rpx;
  padding-top: 8rpx;
}

.loading-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: var(--text-hint);
  animation: dotPulse 1.4s infinite ease-in-out;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.2; }
  40% { opacity: 1; }
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border);
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  background: var(--bg-input);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.send-btn {
  margin-left: 12rpx;
  padding: 18rpx 28rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  transition: all 0.15s;
}

.send-active {
  background: var(--accent-dim);
  border-color: var(--accent);
}

.send-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 600;
  letter-spacing: 1rpx;
}
