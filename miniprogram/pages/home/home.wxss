.page {
  padding-bottom: 40rpx;
}

/* 顶部 */
.hero {
  padding: 48rpx 28rpx 28rpx;
}

.hero-greeting {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary);
  display: block;
  letter-spacing: -1rpx;
}

.hero-date {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
  display: block;
  letter-spacing: 2rpx;
}

/* 卡路里卡片 */
.calorie-card {
  margin: 0 28rpx 24rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 32rpx;
  display: flex;
  align-items: center;
}

.ring-wrap {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.ring-canvas {
  width: 220rpx;
  height: 220rpx;
}

.ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.ring-val {
  font-size: 44rpx;
  font-weight: 200;
  color: var(--text-primary);
  line-height: 1;
  display: block;
  font-variant-numeric: tabular-nums;
}

.ring-label {
  font-size: 18rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
  display: block;
  letter-spacing: 2rpx;
}

.calorie-stats {
  margin-left: 36rpx;
  flex: 1;
  display: flex;
  align-items: center;
}

.cal-stat {
  flex: 1;
  text-align: center;
}

.cal-num {
  font-size: 36rpx;
  font-weight: 200;
  color: var(--text-primary);
  display: block;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.cal-label {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
  display: block;
  letter-spacing: 2rpx;
}

.cal-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--border);
}

/* 快捷入口 */
.shortcuts {
  display: flex;
  gap: 12rpx;
  padding: 0 28rpx;
  margin-bottom: 32rpx;
}

.shortcut {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.shortcut-icon {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 200;
  margin-bottom: 8rpx;
}

.shortcut-text {
  font-size: 22rpx;
  color: var(--text-hint);
  letter-spacing: 1rpx;
}

/* 分区标题 */
.section-head {
  padding: 0 28rpx 12rpx;
}

.section-title {
  font-size: 20rpx;
  color: var(--text-hint);
  letter-spacing: 3rpx;
  font-weight: 600;
  text-transform: uppercase;
}

/* 记录列表 */
.record-group-label {
  font-size: 20rpx;
  color: var(--text-hint);
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 14rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.record-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.record-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dot-food {
  background: var(--accent);
}

.dot-exercise {
  background: rgba(168,181,160,0.5);
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
}

.record-meta {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
  display: block;
}

.record-val {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-main {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
}

.empty-sub {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
  display: block;
}
