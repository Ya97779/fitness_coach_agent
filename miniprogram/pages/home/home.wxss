.page {
  padding-bottom: 40rpx;
}

/* 渐变头部 */
.hero {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 50%, #81C784 100%);
  padding: 48rpx 40rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
}

.hero-greeting {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.hero-date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 卡路里环卡片 - 上移覆盖头部 */
.ring-card {
  margin: -48rpx 32rpx 0;
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 40rpx;
}

.ring-container {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.ring-canvas {
  width: 240rpx;
  height: 240rpx;
}

.ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.ring-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
}

.ring-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

.ring-stats {
  margin-left: 40rpx;
  flex: 1;
}

.ring-stat {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.ring-stat:last-child {
  margin-bottom: 0;
}

.ring-stat-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dot-intake {
  background: #4CAF50;
}

.dot-burn {
  background: #2196F3;
}

.ring-stat-val {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1;
}

.ring-stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 快捷入口 */
.shortcuts {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.shortcut-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-guide {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}

.icon-timer {
  background: linear-gradient(135deg, #1A1A2E, #2D2D44);
}

.icon-food {
  background: linear-gradient(135deg, #4CAF50, #81C784);
}

.icon-stats {
  background: linear-gradient(135deg, #2196F3, #64B5F6);
}

.shortcut-text {
  font-size: 22rpx;
  color: #666;
}

/* 分区标题 */
.section-header {
  padding: 32rpx 32rpx 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 记录列表 */
.record-section-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.record-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.dot-food {
  background: #4CAF50;
}

.dot-exercise {
  background: #2196F3;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.record-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.record-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  display: block;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 12rpx;
  display: block;
}
