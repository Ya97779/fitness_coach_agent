<view class="page">
  <!-- 顶部 -->
  <view class="hero">
    <text class="hero-greeting">{{greeting}}</text>
    <text class="hero-date">{{todayStr}}</text>
  </view>

  <!-- 卡路里 -->
  <view class="calorie-card">
    <view class="ring-wrap">
      <canvas canvas-id="calorieRing" id="calorieRing" class="ring-canvas" />
      <view class="ring-center">
        <text class="ring-val">{{remaining}}</text>
        <text class="ring-label">剩余</text>
      </view>
    </view>
    <view class="calorie-stats">
      <view class="cal-stat">
        <text class="cal-num">{{intake}}</text>
        <text class="cal-label">摄入</text>
      </view>
      <view class="cal-divider"></view>
      <view class="cal-stat">
        <text class="cal-num">{{burn}}</text>
        <text class="cal-label">消耗</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="shortcuts">
    <view class="shortcut" bindtap="goLog">
      <text class="shortcut-icon">+</text>
      <text class="shortcut-text">记录饮食</text>
    </view>
    <view class="shortcut" bindtap="goTimer">
      <text class="shortcut-icon">></text>
      <text class="shortcut-text">开始训练</text>
    </view>
    <view class="shortcut" bindtap="goStats">
      <text class="shortcut-icon">~</text>
      <text class="shortcut-text">历史趋势</text>
    </view>
  </view>

  <!-- 今日记录 -->
  <view class="section-head">
    <text class="section-title">今日记录</text>
  </view>

  <view class="card" wx:if="{{foodItems.length > 0}}">
    <text class="record-group-label">饮食</text>
    <view class="record-item" wx:for="{{foodItems}}" wx:key="id">
      <view class="record-dot dot-food"></view>
      <view class="record-info">
        <text class="record-name">{{item.name}}</text>
        <text class="record-meta">{{item.meal_type_text}}</text>
      </view>
      <text class="record-val">{{item.calories}} kcal</text>
    </view>
  </view>

  <view class="card" wx:if="{{exerciseItems.length > 0}}">
    <text class="record-group-label">运动</text>
    <view class="record-item" wx:for="{{exerciseItems}}" wx:key="id">
      <view class="record-dot dot-exercise"></view>
      <view class="record-info">
        <text class="record-name">{{item.type}}</text>
        <text class="record-meta">{{item.duration}} 分钟</text>
      </view>
      <text class="record-val">-{{item.calories}} kcal</text>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && foodItems.length === 0 && exerciseItems.length === 0}}">
    <text class="empty-main">今天还没有记录</text>
    <text class="empty-sub">去聊天或记录页面开始吧</text>
  </view>
</view>
