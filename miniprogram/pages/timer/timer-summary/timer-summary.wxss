.page {
  background: var(--bg-base);
  min-height: 100vh;
  padding: 0 28rpx;
}

/* 顶部 */
.header {
  padding: 48rpx 4rpx 36rpx;
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.header-sub {
  font-size: 20rpx;
  color: var(--text-hint);
  display: block;
  margin-top: 4rpx;
  letter-spacing: 4rpx;
}

/* 统计 */
.stats-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  margin-bottom: 40rpx;
}

.stat-block {
  flex: 1;
  text-align: center;
}

.stat-val {
  font-size: 56rpx;
  font-weight: 200;
  color: var(--text-primary);
  display: block;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  font-size: 20rpx;
  color: var(--text-hint);
  letter-spacing: 2rpx;
  display: block;
  margin-top: 8rpx;
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  height: 72rpx;
  background: var(--border);
}

/* 完成列表 */
.done-section {
  margin-bottom: 60rpx;
}

.done-title {
  font-size: 20rpx;
  color: var(--text-hint);
  letter-spacing: 3rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 14rpx;
  padding-left: 4rpx;
}

.done-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 16rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  margin-bottom: 8rpx;
}

.done-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.done-sets {
  font-size: 24rpx;
  color: var(--text-hint);
  font-variant-numeric: tabular-nums;
}

/* 按钮 */
.bottom-bar {
  padding-bottom: env(safe-area-inset-bottom);
}

.save-btn {
  background: var(--text-primary);
  border-radius: var(--radius-sm);
  padding: 28rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.save-btn.saved {
  opacity: 0.25;
}

.save-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.action-row {
  display: flex;
  justify-content: center;
  gap: 56rpx;
}

.action-link {
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 12rpx;
  letter-spacing: 1rpx;
}
