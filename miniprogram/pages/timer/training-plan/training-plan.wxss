.page {
  min-height: 100vh;
  background: var(--bg-base);
  padding: 24rpx 32rpx;
  padding-bottom: 220rpx;
}

/* ===== 天卡片 ===== */
.day-card {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.day-today {
  background: var(--accent-dim);
  border-color: var(--text-primary);
}

.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.day-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.day-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.day-label-today {
  font-weight: 700;
}

.day-tag {
  font-size: 20rpx;
  color: var(--text-primary);
  background: rgba(26,26,26,0.1);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.day-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.day-summary {
  font-size: 24rpx;
  color: var(--text-hint);
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.day-rest-text {
  color: var(--text-muted);
}

.day-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
  transition: transform 0.2s;
  transform: rotate(90deg);
}

.day-arrow-up {
  transform: rotate(-90deg);
}

/* ===== 展开区 ===== */
.day-body {
  padding: 0 32rpx 28rpx;
  border-top: 1rpx solid var(--border-light);
}

.day-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  flex-wrap: wrap;
}

.action-btn {
  padding: 10rpx 24rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-base);
}

.action-active {
  background: var(--text-primary);
  border-color: var(--text-primary);
}

.action-active .action-text {
  color: #fff;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 动作列表 ===== */
.day-exercises {
  padding-top: 8rpx;
}

.day-ex-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.day-ex-row:last-child {
  border-bottom: none;
}

.day-ex-num {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-hint);
  background: var(--bg-base);
  border-radius: 50%;
  flex-shrink: 0;
}

.day-ex-body {
  flex: 1;
  min-width: 0;
}

.day-ex-name {
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 4rpx 0;
}

.day-placeholder {
  color: var(--text-muted);
  font-size: 28rpx;
}

.day-ex-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.day-stepper {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: var(--bg-base);
  border-radius: var(--radius-sm);
  padding: 4rpx 8rpx;
}

.stepper-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.stepper-val {
  min-width: 40rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
}

.day-ex-sets-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.day-ex-del {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.day-add-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border: 1rpx dashed var(--border);
  border-radius: var(--radius-sm);
  margin-top: 16rpx;
}

.day-add-sign {
  font-size: 28rpx;
  color: var(--text-hint);
}

.day-add-label {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== 底部栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent 0%, var(--bg-base) 30%);
  z-index: 10;
}

.start-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: var(--text-primary);
  border-radius: var(--radius-md);
}

.start-btn.disabled {
  opacity: 0.15;
}

.start-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.start-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 6rpx;
}

/* ===== 模板弹窗 ===== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}

.mask-show {
  opacity: 1;
  pointer-events: auto;
}

.picker-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.sheet-show {
  transform: translateY(0);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-light);
  flex-shrink: 0;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.sheet-close {
  font-size: 36rpx;
  color: var(--text-hint);
  padding: 8rpx;
}

.sheet-body {
  flex: 1;
  overflow: auto;
  padding: 16rpx 32rpx 48rpx;
}

.tpl-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.tpl-row:last-child {
  border-bottom: none;
}

.tpl-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-base);
  border-radius: var(--radius-sm);
}

.tpl-info {
  flex: 1;
}

.tpl-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.tpl-desc {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
  display: block;
}
