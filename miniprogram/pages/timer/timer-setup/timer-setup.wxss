.page {
  background: var(--bg-base);
  min-height: 100vh;
  padding: 0 28rpx 220rpx;
}

/* 顶部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 4rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 28rpx;
}

.header-plan-btn {
  padding: 12rpx 28rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-card);
}

.header-plan-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.header-sub {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}

/* 分区 */
.section {
  margin-bottom: 36rpx;
}

.section-label {
  font-size: 20rpx;
  color: var(--text-hint);
  letter-spacing: 3rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 14rpx;
  padding-left: 4rpx;
}

/* 模板卡片 */
.template-scroll {
  white-space: nowrap;
}

.template-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  margin-right: 12rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  transition: all 0.15s;
}

.template-active {
  border-color: var(--text-primary);
  background: var(--accent-dim);
}

.template-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.template-name {
  font-size: 20rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  letter-spacing: 1rpx;
}

.template-active .template-name {
  color: var(--text-primary);
  font-weight: 600;
}

/* 休息时长 */
.rest-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.rest-btn {
  width: 56rpx;
  height: 56rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
}

.rest-btn-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 300;
  line-height: 1;
}

.rest-display {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.rest-num {
  font-size: 72rpx;
  font-weight: 200;
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.rest-unit {
  font-size: 18rpx;
  color: var(--text-hint);
  letter-spacing: 2rpx;
  font-weight: 600;
}

/* 动作列表 */
.ex-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ex-row {
  display: flex;
  align-items: flex-start;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 16rpx;
  gap: 12rpx;
}

.ex-num {
  width: 36rpx;
  height: 36rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-hint);
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.ex-body {
  flex: 1;
  min-width: 0;
}

.ex-name-input {
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 4rpx 0;
  width: 100%;
}

.ex-placeholder {
  color: var(--text-muted);
}

.ex-meta {
  display: flex;
  gap: 24rpx;
  margin-top: 10rpx;
}

.ex-meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ex-meta-label {
  font-size: 20rpx;
  color: var(--text-hint);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.ex-stepper {
  display: flex;
  align-items: center;
  gap: 0;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.stepper-btn {
  width: 40rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.stepper-val {
  width: 48rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
  border-left: 1rpx solid var(--border);
  border-right: 1rpx solid var(--border);
  padding: 6rpx 0;
}

.ex-rest-input {
  width: 64rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  text-align: center;
  font-variant-numeric: tabular-nums;
  border-bottom: 1rpx solid var(--border);
  padding: 4rpx 0;
}

.ex-del {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 8rpx;
  flex-shrink: 0;
}

/* 添加按钮 */
.add-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-top: 8rpx;
  border: 1rpx dashed var(--border);
  border-radius: var(--radius-md);
  gap: 8rpx;
}

.add-sign {
  font-size: 28rpx;
  color: var(--text-hint);
  font-weight: 300;
}

.add-label {
  font-size: 24rpx;
  color: var(--text-hint);
  letter-spacing: 1rpx;
}

/* 底部 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent 0%, var(--bg-base) 30%);
}

.start-btn {
  background: var(--text-primary);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  text-align: center;
}

.start-btn.disabled {
  opacity: 0.15;
}

.start-main {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  letter-spacing: 2rpx;
}

.start-sub {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 2rpx;
  display: block;
  letter-spacing: 1rpx;
}
