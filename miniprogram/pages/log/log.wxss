.page {
  padding: 0 32rpx 40rpx;
}

/* Tab 切换 */
.tabs {
  display: flex;
  background: #F0F0F0;
  border-radius: 12rpx;
  padding: 6rpx;
  margin: 24rpx 0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.tab-active {
  background: #fff;
  color: #4CAF50;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 表单 */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  background: #F8F9FA;
  border: 2rpx solid #F0F0F0;
  border-radius: 10rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

/* 餐次选择 */
.meal-types {
  display: flex;
  gap: 16rpx;
}

.meal-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  background: #F8F9FA;
  border-radius: 10rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.meal-active {
  color: #4CAF50;
  border-color: #4CAF50;
  background: rgba(76, 175, 80, 0.06);
}

/* 运动快选 */
.quick-types {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.quick-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #F8F9FA;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.quick-active {
  color: #2196F3;
  border-color: #2196F3;
  background: rgba(33, 150, 243, 0.06);
}

.submit-btn {
  margin-top: 40rpx;
}

.submit-btn[disabled] {
  background: #ccc !important;
}
