/* === 全局变量 === */
page {
  --bg-base: #111113;
  --bg-card: rgba(255,255,255,0.04);
  --bg-card-hover: rgba(255,255,255,0.06);
  --bg-input: rgba(255,255,255,0.06);
  --border: rgba(255,255,255,0.08);
  --border-light: rgba(255,255,255,0.05);
  --text-primary: #f0ece4;
  --text-secondary: rgba(255,255,255,0.5);
  --text-hint: rgba(255,255,255,0.25);
  --text-muted: rgba(255,255,255,0.15);
  --accent: #a8b5a0;
  --accent-dim: rgba(168,181,160,0.15);
  --danger: #c47a6c;
  --radius-sm: 4rpx;
  --radius-md: 6rpx;

  background-color: var(--bg-base);
  color: var(--text-primary);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* === 通用卡片 === */
.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
}

/* === 通用按钮 === */
.btn-primary {
  background: var(--text-primary);
  color: var(--bg-base);
  border: none;
  border-radius: var(--radius-sm);
  padding: 22rpx 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* === 页面容器 === */
.page-container {
  padding: 32rpx 28rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* === 通用 flex === */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* === 标签 === */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.tag-primary {
  background: var(--accent-dim);
  color: var(--accent);
}

.tag-accent {
  background: rgba(168,181,160,0.1);
  color: var(--accent);
}

.tag-warning {
  background: rgba(196,122,108,0.12);
  color: var(--danger);
}
