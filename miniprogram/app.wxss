/* === 全局变量 === */
page {
  --bg-base: #f5f5f5;
  --bg-card: #ffffff;
  --bg-input: #f0f0f0;
  --border: #e8e8e8;
  --border-light: #f0f0f0;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-hint: #999999;
  --text-muted: #cccccc;
  --accent: #1a1a1a;
  --accent-dim: rgba(26,26,26,0.06);
  --danger: #c47a6c;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;

  background-color: var(--bg-base);
  color: var(--text-primary);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* === 通用卡片 === */
.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
}

/* === 通用按钮 === */
.btn-primary {
  background: var(--text-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-sm);
  padding: 22rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* === 页面容器 === */
.page-container {
  padding: 32rpx 28rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* === 通用 flex === */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* === 标签 === */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.tag-primary {
  background: var(--accent-dim);
  color: var(--text-primary);
}

.tag-accent {
  background: var(--accent-dim);
  color: var(--text-primary);
}

.tag-warning {
  background: rgba(196,122,108,0.1);
  color: var(--danger);
}
