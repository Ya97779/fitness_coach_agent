# =========================
# 环境变量和机密文件 (绝不能上传!)
# =========================
.env
.env.*
*.pem
*.key

# =========================
# Python 编译和缓存文件
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so

# =========================
# 构建和打包产物
# =========================
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =========================
# 虚拟环境 (以防你在项目内创建了局部环境)
# =========================
.env/
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# =========================
# IDE 和操作系统文件
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# Agent 运行时可能产生的日志或本地数据
# =========================
*.log
*.sqlite3
db.sqlite3
/data/